         <div type="edition" xml:lang="kaw-Latn" rendition="class:38769 maturity:83213">
<pb n="1r"/><!--Blank outer page.-->
<p><pb n="1v"/>
	<lb n="1v1"/><g ref="sym:doubleBar-hooked" type="punctuation">.</g> pavaraḥ I soĀra saṁ maṅilala dravya haji kabaiḥ 
kriṁ<g ref="sym:bullet-hollow" type="punctuation">.</g> 
paḍam·<g ref="sym:bullet-hollow" type="punctuation">.</g> 
pinilai<g ref="sym:bullet-hollow" type="punctuation">.</g> 
kataṅgaran·<g ref="sym:bullet-hollow" type="punctuation">.</g> 
halu varak·<g ref="sym:bullet-hollow" type="punctuation">.</g> 
maṁrumvai<g ref="sym:bullet-hollow" type="punctuation">.</g> 
	<lb n="1v2"/>paranakan·<g ref="sym:bullet-hollow" type="punctuation">.</g> 
paravat·<g ref="sym:bullet-hollow" type="punctuation">.</g> 
mahaliman·<g ref="sym:bullet-hollow" type="punctuation">.</g> 
I<space type="descender"/>tyaivammādi saprakāra saṁ maṅilala dravya ha<space type="descender"/>ji kabaiḥ Ujar saṁ pamgat·
	<lb n="1v3"/>makudur· majara sira I hananikana varahan· <space type="binding-hole"/> saṁ hyaṁ kudur· I vuAṁ got· vatag valā Ikana kunaṁ daiya saṁ maṅila<space type="descender"/>la
	<lb n="1v4"/>dravya haji ka<space type="descender"/>baiḥ tar tamatāta<!-- vārtamavā ta? --> sira Aṅkāna<g ref="sym:bullet-hollow" type="punctuation">.</g>
<!-- aṅkāna = ṅkāna, see Dalinan: ājñā haji kinonakan ikanaṅ masamvyavahāra *aṅkāna hīṅ-hīṅṅana kvaih(1v4)hanya paṇḍai mas -->
 muAṁ saprakārani gavainya kabaiḥ 
madagaṁ<g ref="sym:bullet-hollow" type="punctuation">.</g> 
maṅulaṁ<g ref="sym:bullet-hollow" type="punctuation">.</g> 
paṇḍai<g ref="sym:bullet-hollow" type="punctuation">.</g> 
mañamvul·</p><!-- Arlo: is the text complete or not? If incomplete, apply part="I" on the opening <p> -->
