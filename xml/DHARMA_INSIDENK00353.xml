</lg>
<p><milestone type="pagelike" unit="zone" n="B"/><label xml:lang="eng">Left</label>
<lb n="3"/>sarvveṇa prakāreṇa <space/> sarvvasmin sarvvathā sa<supplied reason="lost">r</supplied>vv<unclear>ā</unclear> 
<lb n="4"/>siddhayāt<supplied reason="lost">r</supplied>ā<supplied reason="omitted">ḥ</supplied> santu
<milestone type="pagelike" unit="zone" n="C"/><label xml:lang="eng">Right</label>
<lb n="5"/>sa<supplied reason="lost">rv</supplied>v<seg type="component" subtype="vowel"><gap reason="lost" quantity="1" unit="component"/></seg><unclear cert="low">ka</unclear> <gap reason="lost" unit="character" quantity="5"/><seg type="component" subtype="body"><gap reason="lost" quantity="1" unit="component"/></seg>r<seg type="component" subtype="vowel"><gap reason="lost" quantity="1" unit="component"/></seg><gap reason="lost" unit="character" quantity="2"/><gap reason="illegible" unit="character" quantity="1"/><gap reason="lost" unit="character" quantity="1"/>
